generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]

  @@map("categories")
}

model Project {
  id               String            @id @default(uuid())
  title            String
  slug             String            @unique
  description      String
  client           String?
  projectDate      DateTime?
  technologies     String[]          @default([])
  coverImage       String?
  bannerImage      String?
  videoUrl         String?
  creativeProcess  String?
  challenges       String?
  finalResult      String?
  isFeatured       Boolean           @default(false)
  featuredOrder    Int?
  categoryId       String
  category         Category          @relation(fields: [categoryId], references: [id])
  images           ProjectImage[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("projects")
}

model ProjectImage {
  id        String   @id @default(uuid())
  url       String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("project_images")
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String
  icon        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("services")
}

model Skill {
  id         String   @id @default(uuid())
  name       String
  percentage Int
  icon       String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("skills")
}

model Experience {
  id          String    @id @default(uuid())
  company     String
  position    String
  description String
  startDate   DateTime
  endDate     DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("experiences")
}

model Message {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("messages")
}

model SocialLink {
  id        String   @id @default(uuid())
  platform  String   @unique // linkedin, behance, instagram, youtube, facebook, whatsapp, github
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("social_links")
}

model Settings {
  id            String   @id @default(uuid())
  websiteTitle  String   @default("My Portfolio")
  logo          String?
  favicon       String?
  themeColor    String   @default("#000000")
  footerText    String?
  seoTitle      String?
  seoDescription String?
  seoKeywords   String?
  biography     String?
  heroText      String?
  profilePicture String?
  resumeUrl     String?
  yearsExperience Int?   @default(0)
  projectsCompleted Int? @default(0)
  happyClients  Int?     @default(0)
  updatedAt     DateTime @updatedAt

  @@map("settings")
}
